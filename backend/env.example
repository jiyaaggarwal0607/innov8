# ── DATABASE ──
MONGO_URI=mongodb://localhost:27017/safevoice
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/safevoice

# ── JWT ──
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── ANTHROPIC ──
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── SERVER ──
PORT=4000
ALLOWED_ORIGIN=http://localhost:3000
NODE_ENV=development
