# ── DATABASE (MySQL) ──
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=safevoice

# ── SECURITY ──
ENCRYPTION_KEY=replace_with_a_32_byte_random_hex_string_exactly_64_characters
# You can generate a key by running in terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── JWT ──
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── ANTHROPIC ──
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── SERVER ──
PORT=5000
ALLOWED_ORIGIN=http://localhost:3000
NODE_ENV=development